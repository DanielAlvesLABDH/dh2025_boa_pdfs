        <body>
            <div>
                <figure>
                    <graphic n="1001" width="16.002cm" height="9.001125cm" url="/tmp/tmp7xh1zawv/Pictures/4570cc9edbaa6a125e3b437b6b26a1b3.jpeg" rend="inline"/>
                    <head>
